APP_ENV=development

# API settings
API_HOST=0.0.0.0
API_PORT=8000
DATA_DIR=/data
SQLITE_PATH=/data/flashcards.sqlite
AUDIO_CACHE_DIR=/data/audio_cache
SERVE_WEB=false

# CORS. Comma-separated origins. Same-origin deployment needs no CORS.
# For a separate frontend, set e.g. https://app.example.com. In production, never use *.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# CSV import: max upload size in bytes (default 52428800 = 50 MiB). Clamped to 1 MiB–500 MiB.
# CSV_UPLOAD_MAX_BYTES=52428800

# Auth (required). Use a strong secret in production (at least 32 bytes for HS256).
JWT_SECRET=your-secret-at-least-32-characters-long

